# Example environment variables for Portals IDE.
# This app does not require any environment configuration by default.

# Set a custom terminal shell path for the built-in terminal.
# Example: TERMINAL_SHELL=/usr/bin/zsh
TERMINAL_SHELL=/usr/bin/zsh

# Optional: Set up an AI assistant. Choose one provider below.
# Leave all blank to disable AI.

# === ANTHROPIC (Claude API) ===
# Get your key from: https://console.anthropic.com/account/keys
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# === OLLAMA (Local LLM) ===
# Download from: https://ollama.ai
# Run: ollama pull llama2 (or qwen, etc.)
# AI_PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama2

# === FIREWORKS (API) ===
# Get your key from: https://app.fireworks.ai
# AI_PROVIDER=fireworks
# FIREWORKS_API_KEY=your-api-key-here
# FIREWORKS_MODEL=accounts/fireworks/models/llama-v2-7b-chat
